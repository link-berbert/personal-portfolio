# Optional: override the canonical + og:url host (defaults to https://www.lincolnberbert.com).
# Use for staging previews. No trailing slash.
# VITE_SITE_ORIGIN=https://preview.example.com
VITE_SITE_ORIGIN=

# Web3Forms (https://web3forms.com) — free tier, emails you on submit. Add the same key in
# Vercel → Project → Settings → Environment Variables. Restrict allowed domains in Web3Forms.
# VITE_WEB3FORMS_ACCESS_KEY=
